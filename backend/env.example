# NetControl Backend Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Generate strong random strings:
#   openssl rand -hex 64
JWT_SECRET=CHANGE_ME_USE_STRONG_RANDOM_STRING_AT_LEAST_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_STRONG_RANDOM_STRING_64_CHARS
JWT_EXPIRY=8h
JWT_REFRESH_EXPIRY=7d

# ── Credential Encryption Key ─────────────────────────────────────────────────
# AES-256 key — must be EXACTLY 32 characters
# Generate: openssl rand -hex 16   (gives exactly 32 hex chars)
CREDENTIAL_ENCRYPTION_KEY=CHANGE_ME_EXACTLY_32_CHARACTERS!!

# ── Action PIN ────────────────────────────────────────────────────────────────
# This PIN is required before any power action (wake/shutdown/restart).
# Store only the bcrypt hash here — never the plain PIN.
#
# Generate the hash for your chosen PIN (e.g. "1234"):
#   node -e "const b=require('bcryptjs'); b.hash('YOUR_PIN', 12).then(console.log)"
#
ACTION_PIN_HASH=$2b$12$REPLACE_THIS_WITH_REAL_BCRYPT_HASH_OF_YOUR_PIN

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=./db/netcontrol.db

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to the exact origin of your frontend (no trailing slash)
CORS_ORIGIN=http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# RATE_LIMIT_WINDOW_MS — window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Max general API requests per window per IP
RATE_LIMIT_MAX=100

# Max power-action requests per window per user (stricter)
ACTION_RATE_LIMIT_MAX=20
