# NetControl Backend Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Generate strong random strings:
#   openssl rand -hex 64
JWT_SECRET="QO7DUUS9DCR1KGPU2417MFZGHXLPUR6RBEC99PV2D7UZBO9WVVK5L95636NAKOA0UHJ0H52T3P036F5NF67UDOH3NEFFG9FS"
JWT_REFRESH_SECRET="X5Q9Z30EKQ9YESH2DZWEINE52GU5YMALAS41Z8ER6BITNWMMHAY5XYP5OVJGEGC60JQF2X9EHJ95O6IJKDBQVHZBDNUPX40L"
JWT_EXPIRY=8h
JWT_REFRESH_EXPIRY=7d

# ── Credential Encryption Key ─────────────────────────────────────────────────
# AES-256 key — must be EXACTLY 32 characters
# Generate: openssl rand -hex 16   (gives exactly 32 hex chars)
CREDENTIAL_ENCRYPTION_KEY=9b70b3d357983f920321aab9d3fe08f8


# ── Action PIN ────────────────────────────────────────────────────────────────
# This PIN is required before any power action (wake/shutdown/restart).
# Store only the bcrypt hash here — never the plain PIN.
#
# Generate the hash for your chosen PIN (e.g. "1234"):
#   node -e "const b=require('bcryptjs'); b.hash('YOUR_PIN', 12).then(console.log)"
#
ACTION_PIN_HASH="$2a$12$amuB6BxmMXfCN5Xhwt5E5.aa88f9B3OV773kiyqyWIoyPEJ5RhBSS"


# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=netcontrol
DB_PASSWORD=macwol
DB_NAME=netcontrol
DB_ROOT_PASSWORD=root

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to the exact origin of your frontend (no trailing slash)
CORS_ORIGIN=http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# RATE_LIMIT_WINDOW_MS — window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Max general API requests per window per IP
RATE_LIMIT_MAX=100

# Max power-action requests per window per user (stricter)
ACTION_RATE_LIMIT_MAX=20
